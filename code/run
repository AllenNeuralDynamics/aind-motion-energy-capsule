#!/usr/bin/env bash
set -ex
# Thin shell over the aind-motion-energy library CLI (installed from the env).
# Processes every video under /data (full length by default) and writes results
# to /results. Per-run overrides (--roi, --end-frame, a single --input file, ...)
# arrive via "$@" from the Code Ocean App Builder / batch launcher — never edit
# this file to change parameters.
aind-motion-energy \
    --input /root/capsule/data \
    --output /root/capsule/results \
    --summary-plots \
    "$@"
